# =============================================================================
# GRIZL Snowflake Observability — config template
# =============================================================================
# Copy this file to grizl.snowflake.env and fill in your values.
# grizl.snowflake.env is gitignored. NEVER commit the filled-in file.
#
# The Snowflake CLI (snow) uses connections defined in ~/.snowflake/connections.toml.
# Set up a named connection for the scripts in this repo:
#
#   snow connection add grizl \
#     --account <YOUR_ACCOUNT> \
#     --user <YOUR_USER> \
#     --role grizl_role \
#     --warehouse grizl_wh \
#     --database grizl \
#     --schema observability \
#     --authenticator externalbrowser   # or private-key-path / password
#
# Test: snow connection test --connection grizl
# =============================================================================

# Snowflake CLI connection name (references ~/.snowflake/connections.toml)
export SNOWFLAKE_CONNECTION=grizl

# Snowflake account identifier (e.g. your-account.snowflakecomputing.com or
# org-account form: your-org-your-account)
export SNOWFLAKE_ACCOUNT=your-account.snowflakecomputing.com

# Snowflake username
export SNOWFLAKE_USER=your-user

# Snowflake objects (match what provision.sh creates)
export SNOWFLAKE_DATABASE=grizl
export SNOWFLAKE_SCHEMA=observability
export SNOWFLAKE_WAREHOUSE=grizl_wh
export SNOWFLAKE_ROLE=grizl_role

# GCS bucket — same bucket used by the grizl-databricks-observability Pub/Sub
# Cloud Storage export subscription (or create a separate bucket for Snowflake).
# Must match the STORAGE_ALLOWED_LOCATIONS in GRIZL_GCS_INTEGRATION.
export GCS_LOGS_BUCKET=your-gcs-logs-bucket
export GCS_LOGS_PATH=logs/
export GCP_PROJECT_ID=

# Cortex Agent name (for reference and test scripts)
# Created by the Cortex Agent REST API or Snowsight.
export SNOWFLAKE_CORTEX_AGENT_NAME=grizl_incident_agent

# External incident orchestrator webhook URL.
# Stored as a Snowflake secret (GRIZL.OBSERVABILITY.ORCHESTRATOR_WEBHOOK_SECRET)
# — do not commit the actual URL here. Reference only.
export ORCHESTRATOR_WEBHOOK_URL=https://your-orchestrator.example.com/api/snowflake/incidents

# Snowflake REST API token for cortex-agent-mgmt.sh test commands.
# Generate: snow login token --connection grizl
# Or use: snow generate-jwt --connection grizl
# DO NOT commit this value. Set in shell session or read from a secret manager.
# export SNOWFLAKE_TOKEN=
